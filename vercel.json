{
  "version": 2,
  "framework": "astro",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "cleanUrls": true,
  "redirects": [
    { "source": "/partner-kit", "destination": "/partnership/affiliate/partner-kit", "permanent": true },
    { "source": "/affiliate", "destination": "/partnership/affiliate", "permanent": true },
    { "source": "/product", "destination": "/products", "permanent": true },
    { "source": "/brand-engine", "destination": "/tools/brand-engine", "permanent": true },
    { "source": "/website-auditor", "destination": "/tools/website-auditor", "permanent": true },
    { "source": "/policy", "destination": "/partnership/policy", "permanent": true },
    { "source": "/emmy-sign", "destination": "/tools/emmy-sign", "permanent": true },
    { "source": "/naira-wise", "destination": "/tools/naira-wise", "permanent": true },
    { "source": "/social-architect", "destination": "/tools/social-architect", "permanent": true },
    { "source": "/digital-business-card", "destination": "/products/digital-business-card", "permanent": true },
    { "source": "/meeting_background_studio", "destination": "/tools/meeting_background_studio", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/document-engine",
      "destination": "https://emmystack01.github.io/Emmy_STACK01-Document-Engine-Website/"
    },
    {
      "source": "/document-engine/:path*",
      "destination": "https://emmystack01.github.io/Emmy_STACK01-Document-Engine-Website/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,POST" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
      ]
    }
  ]
}
