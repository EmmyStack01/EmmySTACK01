{
	"version": 3,
	"routes": [
		{
			"src": "^/(.*)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/_image$",
			"dest": "_render"
		},
		{
			"src": "^/404$",
			"dest": "_render"
		},
		{
			"src": "^/api/keystatic(?:/(.*?))?$",
			"dest": "_render"
		},
		{
			"src": "^/articles/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/articles$",
			"dest": "_render"
		},
		{
			"src": "^/go$",
			"dest": "_render"
		},
		{
			"src": "^/keystatic(?:/(.*?))?$",
			"dest": "_render"
		},
		{
			"src": "^/partnership/affiliate/partner-kit$",
			"dest": "_render"
		},
		{
			"src": "^/partnership/affiliate$",
			"dest": "_render"
		},
		{
			"src": "^/partnership/policy$",
			"dest": "_render"
		},
		{
			"src": "^/partnership$",
			"dest": "_render"
		},
		{
			"src": "^/payment$",
			"dest": "_render"
		},
		{
			"src": "^/preview$",
			"dest": "_render"
		},
		{
			"src": "^/pricing$",
			"dest": "_render"
		},
		{
			"src": "^/products/digital-business-card$",
			"dest": "_render"
		},
		{
			"src": "^/products$",
			"dest": "_render"
		},
		{
			"src": "^/success$",
			"dest": "_render"
		},
		{
			"src": "^/thank-you$",
			"dest": "_render"
		},
		{
			"src": "^/tools/brand-engine$",
			"dest": "_render"
		},
		{
			"src": "^/tools/emmy-sign$",
			"dest": "_render"
		},
		{
			"src": "^/tools/meeting_background_studio$",
			"dest": "_render"
		},
		{
			"src": "^/tools/naira-wise$",
			"dest": "_render"
		},
		{
			"src": "^/tools/social-architect$",
			"dest": "_render"
		},
		{
			"src": "^/tools/website-auditor$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}