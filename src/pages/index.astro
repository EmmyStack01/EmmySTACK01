<script>
document.addEventListener("DOMContentLoaded", () => {
    // Register ScrollTrigger plugin
    gsap.registerPlugin(ScrollTrigger);

    gsap.set(".line-one, .line-two, .content-p, .hero-cta, .menu-tile, .process-step, .process-arrow, .product-info, .product-image", { visibility: "visible" });

    // 1. HERO SECTION (Runs on Page Load)
    const heroTl = gsap.timeline();

    heroTl.from(".line-one", { 
        x: -50, 
        opacity: 0, 
        duration: 2, 
        ease: "power4.out" 
    })
    .from(".line-two", { 
        x: 50, 
        opacity: 0, 
        duration: 1.2, 
        ease: "power4.out" 
    }, "-=1")
    .from(".content-p", { 
        y: 20, 
        opacity: 0, 
        duration: 0.8 
    }, "-=0.5")
    .from(".hero-cta", { 
        scale: 0, 
        opacity: 0, 
        duration: 0.5, 
        ease: "back.out(1.7)" 
    }, "-=0.3");

    // 2. Animate the Section Heading (h2) - Your existing code works fine here
    gsap.from(".menu-section h2", {
        scrollTrigger: {
            trigger: ".menu-section h2",
            start: "top 90%",
            toggleActions: "play none none none"
        },
        y: 30,
        opacity: 0,
        duration: 1,
        ease: "power3.out"
    });

    // 3. Updated Grid Animation for Menu Tiles
    const menuTiles = document.querySelectorAll(".menu-tile");

    menuTiles.forEach((tile, index) => {
        gsap.from(tile, {
            scrollTrigger: {
                trigger: tile,      // Each tile is its own trigger
                start: "top 88%",   // Starts when the individual tile is near the bottom
                toggleActions: "play none none none",
                // markers: true,   // Uncomment this to see exactly where they trigger
            },
            y: 40,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out",
            // No stagger needed here because the scroll itself creates the delay!

            delay: (index % 2) * 0.15 // Adds a 0.15s delay to every second tile (the right column)
        });
    });

    const processSteps = document.querySelectorAll(".process-step");

    // Process section
    processSteps.forEach((step, index) => {
        gsap.from(step, {
            scrollTrigger: {
                trigger: step,       // Each step triggers itself
                start: "top 85%",    // Animates when the step is 85% from the top
                toggleActions: "play none none none"
            },
            y: 60,                   // Moves up from 60px below
            opacity: 0,
            duration: 1.2,
            ease: "power4.out",      // Smooth, high-end feel
            // Small delay for desktop if they are side-by-side
            delay: window.innerWidth > 860 ? index * 0.1 : 0 
        });
    });
    // Optional: Make the arrows pulse slightly after the step appears
    gsap.to(".process-arrow", {
        x: 5,
        repeat: -1,
        yoyo: true,
        duration: 0.8,
        ease: "sine.inOut"
    });

    // Product Section Slide In
    gsap.from(".product-info", {
        scrollTrigger: {
            trigger: ".product",
            start: "top 75%",
        },
        x: -100,
        opacity: 0,
        duration: 2,
        ease: "power2.out"
    });

    gsap.from(".product-image", {
        scrollTrigger: {
            trigger: ".product",
            start: "top 75%",
        },
        x: 100,
        opacity: 0,
        duration: 2,
        ease: "power2.out"
    });

    // FAQ Items Fade In
    gsap.from(".faq-item", {
        scrollTrigger: {
            trigger: ".faq",
            start: "top 85%",
        },
        opacity: 0,
        y: 20,
        stagger: 0.2,
        duration: 0.8
    });
});
    

</script>
