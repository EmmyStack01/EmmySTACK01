    <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        // Register ScrollTrigger plugin
        gsap.registerPlugin(ScrollTrigger);

        gsap.set(".line-one, .line-two, .content-p, .hero-cta, .phone-display-video, .product-hero, .phone-frame, .product-card ", { visibility: "visible" });

        // 1. HERO SECTION (Runs on Page Load)
        const heroTl = gsap.timeline();

        heroTl.from(".line-one", { 
            x: -50, 
            opacity: 0, 
            duration: 2, 
            ease: "power4.out" 
        })
        .from(".line-two", { 
            x: 50, 
            opacity: 0, 
            duration: 1.2, 
            ease: "power4.out" 
        }, "-=1")
        .from(".content-p", { 
            y: 20, 
            opacity: 0, 
            duration: 0.8 
        }, "-=0.5")
        .from(".hero-cta", { 
            scale: 0, 
            opacity: 0, 
            duration: 0.5, 
            ease: "back.out(1.7)" 
        }, "-=0.3");


        const vCardVideo = document.querySelector(".phone-display-video");

        // 1. Sync video to scroll
        gsap.to(vCardVideo, {
            scrollTrigger: {
                trigger: ".product-hero",
                start: "top top",
                end: "bottom top",
                scrub: true
            },
            currentTime: vCardVideo.duration || 5
        });

        // 2. Continuous Floating Animation
        gsap.to(".phone-frame", {
            y: 20,
            rotationY: 5,
            rotationX: 2,
            duration: 3,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });

        // 3. Desktop Interactive Tilt & Grid Move
        if (window.innerWidth > 1024) {
            document.addEventListener("mousemove", (e) => {
                const xPos = (e.clientX / window.innerWidth) - 0.5;
                const yPos = (e.clientY / window.innerHeight) - 0.5;

                // Tilt Phone
                gsap.to(".phone-frame", {
                    rotationY: xPos * 25,
                    rotationX: -yPos * 25,
                    duration: 1.2,
                    ease: "power2.out"
                });

                // Move Grid
                gsap.to(".product-hero", {
                    backgroundPosition: `${50 + xPos * 30}px ${50 + yPos * 30}px`,
                    duration: 1.5,
                    ease: "power2.out"
                });
            });
        }

        // Register ScrollTrigger if you haven't already
        gsap.registerPlugin(ScrollTrigger);

        // --- CREATE MATCHMEDIA INTERFACE ---
            let mm = gsap.matchMedia();

            // This block only runs when the viewport is WIDER than 480px
            mm.add("(min-width: 481px)", () => {

            // Target all cards and loop through them
            const allCards = gsap.utils.toArray(".product-card");

            allCards.forEach((card) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,      // The card itself triggers the animation
                        start: "top 90%",   // Start when the top of the card is 90% down the screen
                        toggleActions: "play none none none", // Plays once when entering
                        // markers: true,   // Uncomment this to see the start/end lines for debugging
                    },
                    y: 60,                  // Slightly reduced distance for a smoother feel
                    opacity: 0,
                    duration: 1.2,
                    ease: "power3.out"      // Power3 provides a more natural "organic" deceleration
                });
            });
        });
        // --- END MATCHMEDIA ---

        // GSAP 3D Hover Effect for the Product Image
        if (window.innerWidth > 1024) {
            const card = document.querySelector('.product-card.featured');
            const image = document.querySelector('.vcard-preview-img');

            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const xPos = ((e.clientX - rect.left) / rect.width) - 0.5;
                const yPos = ((e.clientY - rect.top) / rect.height) - 0.5;

                gsap.to(image, {
                    rotationY: xPos * 20, /* Tilts as you move mouse left/right */
                    rotationX: -yPos * 20, /* Tilts as you move mouse up/down */
                    duration: 1,
                    ease: "power2.out"
                });
            });

            // Reset rotation when mouse leaves
            card.addEventListener('mouseleave', () => {
                gsap.to(image, { rotationY: 0, rotationX: 0, duration: 1 });
            });
        }
    });
    </script>
