    <script is:inline>
        // 1. GLOBAL STATE
        let featureCount = 2; 

        // 2. UI HELPERS
        function pingCart() {
            const badge = document.querySelector(".cart-badge");
            if(!badge) return;
            gsap.fromTo(badge, { scale: 1 }, { 
                scale: 1.5, duration: 0.2, yoyo: true, repeat: 1, ease: "back.out(2)"
            });
        }

        function updateCartState() {
            // Select BOTH feature chips and integration chips
            const selected = document.querySelectorAll('.feature-chip.is-selected, .integration-chip.is-selected');
            const selectedCount = selected.length;
            const badge = document.querySelector('.cart-badge');
            const launchBtn = document.getElementById('launchBtn');
            
            const newTotal = 2 + selectedCount;
            
            if (newTotal !== featureCount) {
                featureCount = newTotal;
                badge.innerText = featureCount;
                pingCart(); // Animate the badge on change
            }

            // Toggle button "active" look
            if (selectedCount > 0) {
                launchBtn.style.opacity = "1";
                launchBtn.style.pointerEvents = "auto";
            } else {
                // Optional: make it look disabled if nothing is selected
                launchBtn.style.opacity = "0.5";
            }
        }

        // 3. SELECTION LOGIC
        function toggleFeature(element) {
            element.classList.toggle('is-selected');
            const icon = element.querySelector('.ri-add-line, .ri-check-line');
            
            if (element.classList.contains('is-selected')) {
                if(icon) icon.classList.replace('ri-add-line', 'ri-check-line');
            } else {
                if(icon) icon.classList.replace('ri-check-line', 'ri-add-line');
            }
            updateCartState();
        }

        function selectIntegration(element) {
            const parentGroup = element.parentElement; 
            const isAlreadySelected = element.classList.contains('is-selected');

            const siblings = parentGroup.querySelectorAll('.integration-chip');
            siblings.forEach(chip => chip.classList.remove('is-selected'));

            if (!isAlreadySelected) {
                element.classList.add('is-selected');
            }
            updateCartState();
        }

        // 4. DRAWER CONTROLS
        function openDrawer() {
            document.body.classList.add("stop-scrolling");
            gsap.to(".cart-fab", { scale: 0, opacity: 0, duration: 0.3 });
            gsap.to("#cartDrawer", { x: 0, y: 0, duration: 1.2, ease: "expo.out" });
            
            const overlay = document.getElementById("drawerOverlay");
            overlay.style.display = "block";
            gsap.to(overlay, { opacity: 1, duration: 0.5 });
        }

        function closeDrawer() {
            document.body.classList.remove("stop-scrolling");
            gsap.to("#cartDrawer", { x: "100%", y: "100%", duration: 0.8, ease: "power4.in" });
            gsap.to("#drawerOverlay", { 
                opacity: 0, 
                duration: 0.5, 
                onComplete: () => { document.getElementById("drawerOverlay").style.display = "none"; }
            });
            gsap.to(".cart-fab", { scale: 1, opacity: 1, duration: 0.5, delay: 0.3 });
        }

        // 5. ORDER HANDLING
        function handleCardOrder() {
            const btn = document.getElementById('launchBtn');
            const btnText = btn.querySelector('.btn-text');
            const backBtn = document.getElementById('backBtn'); // Ensure your HTML button has id="backBtn"

            // Use 'is-processing' to prevent the selection logic from clashing with checkout
            if (!btn.classList.contains('is-processing')) {
                btn.classList.add('is-processing');
                btnText.innerText = "Processing Stack...";
                
                gsap.to(btn, { backgroundColor: "#00ff88", color: "#000", duration: 0.5 });
                
                setTimeout(() => {
                    btnText.innerText = "Launch via WhatsApp";
                    document.querySelector(".cart-fab").classList.add("ready-state");

                    // VIEW SWAP
                    if(document.getElementById("selectionView")) document.getElementById("selectionView").style.display = "none";
                    if(document.getElementById("summaryView")) document.getElementById("summaryView").style.display = "block";
                    
                    // SHOW THE BACK BUTTON
                    if(backBtn) {
                        backBtn.style.display = "flex";
                        gsap.fromTo(backBtn, { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.3 });
                    }
                }, 1000);
                return;
            }

            // FINAL REDIRECT logic inside handleCardOrder
            btn.disabled = true;
            btnText.innerText = "Connecting...";

            // Inside handleCardOrder, replace your selection loop with this:
            let selections = ["Identity Core", "Smart Sharing"];

            // 1. Grab "More Features" (where text is inside a span.chip-title)
            document.querySelectorAll('.feature-chip.is-selected .chip-title').forEach(span => {
                selections.push(span.innerText.trim());
            });

            // 2. Grab "Integrations" (where text is directly in the chip)
            document.querySelectorAll('.integration-chip.is-selected').forEach(chip => {
                // Only grab the text, ignore the <i> icon
                const cleanName = chip.childNodes[0].textContent.trim();
                if(cleanName) selections.push(cleanName);
            });

            const stackData = encodeURIComponent(selections.join(", "));
            
            setTimeout(() => {
                window.location.href = `/thank-you.html?type=card&stack=${stackData}`;
            }, 1200); 
        }

        // NEW: FUNCTION FOR THE BACK BUTTON
        function goBackToSelection() {
            const btn = document.getElementById('launchBtn');
            const btnText = btn.querySelector('.btn-text');
            const backBtn = document.getElementById('backBtn');

            // 1. CRITICAL: Re-enable the button so it can be clicked again
            btn.disabled = false; 

            // 2. Remove processing state and reset button text
            btn.classList.remove('is-processing');
            btnText.innerText = "Review Stack";

            // 3. Reset the button color and clear GSAP overrides
            // This returns it to your original blue CSS styling
            gsap.to(btn, { 
                backgroundColor: "", 
                color: "", 
                opacity: 1, 
                duration: 0.3 
            });

            // 4. Reset the icon (if it changed to "Connecting...")
            const icon = btn.querySelector('i');
            if (icon) icon.className = "ri-arrow-right-line";

            // 5. Hide Back Button
            if(backBtn) backBtn.style.display = "none";

            // 6. Switch Views back
            if(document.getElementById("summaryView")) document.getElementById("summaryView").style.display = "none";
            if(document.getElementById("selectionView")) document.getElementById("selectionView").style.display = "block";
        }

        // 2. Animations and ScrollTriggers
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger);
            gsap.set(".line-one, .line-two, .content-p, .hero-cta, .demo-hero-cta, .card", { opacity: 1, visibility: "visible" });
            
            // Entrance Timeline
            const heroTl = gsap.timeline();
            heroTl.from(".line-one", { x: -50, opacity: 0, duration: 1.5, ease: "power4.out" })
                .from(".line-two", { x: 50, opacity: 0, duration: 1.2, ease: "power4.out" }, "-=1")
                .from(".content-p", { y: 20, opacity: 0, duration: 0.8 }, "-=0.5")
                .from(".hero-cta", { scale: 0, opacity: 0, stagger: 0.2, ease: "back.out(1.7)" }, "-=0.3")
                .from(".demo-hero-cta", { scale: 0, opacity: 0, duration: 0.8, ease: "back.out(1.7)" }, "-=0.001");

            // Initial state remains the same: Hidden
            gsap.set(".cart-fab", { 
                opacity: 0, 
                scale: 0.5, 
                y: 50, 
                pointerEvents: "none" 
            });

            // New Reveal Logic: Locked to the Package Section
            gsap.to(".cart-fab", {
                scrollTrigger: {
                    trigger: ".package-section", // Target the specific section
                    start: "top 80%",           // Reveal when the top of the section is 80% down the screen
                    end: "bottom 20%",          // Hide again when the bottom of the section reaches 20% from the top
                    toggleActions: "play reverse play reverse", // Entry/Exit animations
                    // markers: true,            // Uncomment this to see the trigger lines while testing
                },
                y: 0, 
                opacity: 1,
                visibility: "visible", 
                scale: 1, 
                pointerEvents: "auto", 
                duration: 0.6, 
                ease: "back.out(1.7)" 
            });

            const vCardVideo = document.querySelector(".phone-display-video");

            // 1. Sync video to scroll
            gsap.to(vCardVideo, {
                scrollTrigger: {
                    trigger: ".product-hero",
                    start: "top top",
                    end: "bottom top",
                    scrub: true
                },
                currentTime: vCardVideo.duration || 5
            });

            // 2. Continuous Floating Animation
            gsap.to(".phone-frame", {
                y: 20,
                rotationY: 5,
                rotationX: 2,
                duration: 3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut"
            });

            // 3. Desktop Interactive Tilt & Grid Move
            if (window.innerWidth > 1024) {
                document.addEventListener("mousemove", (e) => {
                    const xPos = (e.clientX / window.innerWidth) - 0.5;
                    const yPos = (e.clientY / window.innerHeight) - 0.5;

                    // Tilt Phone
                    gsap.to(".phone-frame", {
                        rotationY: xPos * 25,
                        rotationX: -yPos * 25,
                        duration: 1.2,
                        ease: "power2.out"
                    });

                    // Move Grid
                    gsap.to(".product-hero", {
                        backgroundPosition: `${50 + xPos * 30}px ${50 + yPos * 30}px`,
                        duration: 1.5,
                        ease: "power2.out"
                    });
                });
            }

            // Card Scroll Animations
            // Target all cards and loop through them
            const allCards = gsap.utils.toArray(".card-animate");

            allCards.forEach((card) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,      // The card itself triggers the animation
                        start: "top 90%",   // Start when the top of the card is 90% down the screen
                        toggleActions: "play none none none", // Plays once when entering
                        // markers: true,   // Uncomment this to see the start/end lines for debugging
                    },
                    y: 60,                  // Slightly reduced distance for a smoother feel
                    opacity: 0,
                    duration: 1.2,
                    ease: "power3.out"      // Power3 provides a more natural "organic" deceleration
                });
            });

            // 5. DEMO SECTION: Entrance Animation
            gsap.from(".card", {
                scrollTrigger: {
                    trigger: ".container",
                    start: "top 85%", // Triggers when the container is 85% from the top
                    toggleActions: "play none none none",
                },
                x: -800,          // Start 800px to the left (off-screen)
                rotation: -20,    // Add a slight tilt as they fly in
                opacity: 0,
                stagger: 0.15,    // Time gap between each card "dealing"
                duration: 1.2,
                ease: "power4.out", // Fast start, smooth deceleration
                onComplete: function() {
                    // Crucial: Clear the inline 'x' and 'opacity' so your CSS takes back over
                    gsap.set(".card", { clearProps: "x,opacity,rotation" });
                }
            });
            // 7. FOOTER: Smooth Fade
            gsap.from(".footer", {
                scrollTrigger: {
                    trigger: ".footer-section",
                    start: "top bottom",
                },
                opacity: 0,
                duration: 1.5
            });
        });
    </script>
<script src="/script/smooth-scroll.js" defer></script>   
<script src="/script/card.js" defer></script>
<script src="/script/year.js" defer></script>    
</body>
</html>
