            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;
            z-index: 1200;
        }
        .overlay.show {
            opacity: 1;
            visibility: visible;
        }

        /* ── DRAWER PANEL ────────────────────────────────────── */
