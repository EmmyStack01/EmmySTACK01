            .nav-links button.nav-link-scrolled:hover {
                color: white;
            }

            /* ── Desktop dropdown panel — matches drawer submenu aesthetic ── */
            .dropdown-content {
                display: block;
                position: absolute;
                top: calc(100% + 8px);
                left: 50%;
                transform: translateX(-50%) translateY(-8px);
                background: rgba(5, 10, 25, 0.97);
