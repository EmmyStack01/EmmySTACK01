            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 0;
        }

        /* Latest Entries Grid */
        .latest-section-title {
            font-size: 1.25rem;
            color: #fff;
            margin-bottom: 1.5rem;
            letter-spacing: 0.5px;
            border-left: 3px solid #00ccff;
            padding-left: 0.75rem;
        }
        .articles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 2rem;
        }
        .article-card {
            display: flex;
            flex-direction: column;
            overflow: hidden;
            height: 100%;
        }
        .article-image-wrap {
            height: 200px;
            overflow: hidden;
            position: relative;
            background: #161b22;
        }
        .article-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .article-image-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #313841;
        }
        .article-image-placeholder i { font-size: 2rem; }
        .article-category-badge {
            position: absolute;
            top: 1rem; left: 1rem;
            background: rgba(13, 17, 23, 0.85);
            color: #00ccff;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            border: 1px solid rgba(0, 204, 255, 0.3);
        }
        .article-body {
            padding: 1.5rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }
        .article-meta {
            display: flex;
            gap: 0.75rem;
            font-size: 0.75rem;
            color: #8b949e;
            margin-bottom: 0.75rem;
        }
        .article-body h4 {
            font-size: 1.2rem;
            color: #fff;
            margin: 0 0 0.75rem 0;
            line-height: 1.4;
        }
        .article-body h4 a {
            color: inherit;
            text-decoration: none;
            transition: color 0.2s;
        }
        .article-body p {
            color: #8b949e;
            font-size: 0.85rem;
            line-height: 1.5;
            margin: 0 0 1.5rem 0;
            flex-grow: 1;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .article-footer { margin-top: auto; }
        .article-read-link {
            color: #00ccff;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        /* ── MOBILE OPTIMIZATIONS (max-width: 768px) ── */
        @media (max-width: 768px) {
