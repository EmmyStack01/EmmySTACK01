---
export const prerender = true;
// src/pages/articles/index.astro
import { keystaticReader } from '../../reader';

// 1. Fetch all live entries from your Keystatic collection
const rawArticles = await keystaticReader.collections.articles.all();

// 2. Sort them by date descending (Newest first) so your absolute freshest insight is always featured
const sortedArticles = rawArticles.sort((a, b) => {
  return new Date(b.entry.date).getTime() - new Date(a.entry.date).getTime();
});

// 3. Map the Keystatic structure into clean, flat objects that match your exact design markup variables
const articles = sortedArticles.map(article => ({
  title: article.entry.title,
  description: article.entry.description,
  slug: article.slug,
  date: article.entry.date,
  readingTime: article.entry.readingTime,
  category: article.entry.category,
  image: article.entry.coverImage
}));

// Create the clean schema object on the server side
const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "The Digital DNA Log | Emmy STACK01 Articles",
  "description": "Explore insights on digital identity, SEO personal portfolios, and the future of networking in 2026.",
  "url": Astro.url.href,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": articles.length,
    "itemListElement": articles.map((article, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `${Astro.url.origin}/articles/${article.slug}`,
      "name": article.title
    }))
  }
};

// 4. Safely extract your featured banner and grid items using your original pattern
const [featuredArticle, ...otherArticles] = articles;
