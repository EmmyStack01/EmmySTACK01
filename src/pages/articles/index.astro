        <script>
        function checkSubscriptionStatus() {
            const urlParams = new URLSearchParams(window.location.search);
            const status = urlParams.get('status');
            
            if (status === 'success' || status === 'confirmed') {
            const modal = document.getElementById('successModal');
            
            // If the user clicked the link in their email and is fully confirmed:
            if (status === 'confirmed') {
                document.getElementById('modalSubtitle').innerText = "Verification Complete";
                document.getElementById('modalTitle').innerText = "INTEGRATION COMPLETE";
                document.getElementById('modalDescription').innerHTML = "Welcome to the <strong>STACK01 Ecosystem</strong>. Your insider access is officially active. Prepare for upcoming premium drops, hidden technical documentation, and tracking updates sent straight to your inbox.";
                // Optional: Change icon to something cooler for full verification
                document.getElementById('modalIcon').innerText = "✦"; 
            }
            
            // Reveal the pop-up
            modal.style.display = 'flex';
            
            // Polish the browser URL bar so the parameters vanish
            const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
            window.history.replaceState({path: cleanUrl}, '', cleanUrl);
            }
        }

        window.closeSuccessModal = function() {
            document.getElementById('successModal').style.display = 'none';
