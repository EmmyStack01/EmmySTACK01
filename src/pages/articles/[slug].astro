---
// src/pages/articles/[slug].astro
import { keystaticReader } from '../../reader';
import ArticleRenderer from '../../components/ArticleRenderer';

const { slug } = Astro.params;

const article = await keystaticReader.collections.articles.read(slug);

if (!article) {
  return Astro.redirect('/articles');
}

const content = await article.content();
const title = article.title;
const description = article.description;
const date = article.date;
const category = article.category;
const readingTime = article.readingTime;
const image = article.coverImage;
const author = article.author;

const fullyQualifiedImage = image
  ? (image.startsWith('http') ? image : `${Astro.url.origin}${image}`)
  : `${Astro.url.origin}/asset/og-image4.jpg`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": fullyQualifiedImage,
  "datePublished": date ? new Date(date).toISOString() : new Date().toISOString(),
  "dateModified": date ? new Date(date).toISOString() : new Date().toISOString(),
  "url": Astro.url.href,
  "author": {
    "@type": "Person",
    "name": author || "Emmy STACK01"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Emmy STACK01",
    "logo": {
      "@type": "ImageObject",
      "url": `${Astro.url.origin}/asset/emmy-stack01-logo.png`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <title>{title} | Emmy STACK01</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={Astro.url.href}>

    <meta property="og:type" content="article">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:url" content={Astro.url.href}>
    <meta property="og:image" content={fullyQualifiedImage}>

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={fullyQualifiedImage}>

    <link rel="apple-touch-icon" sizes="180x180" href="https://emmystack01.com/favicon_io/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="https://emmystack01.com/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://emmystack01.com/favicon_io/favicon-16x16.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&family=Montserrat:wght@300..600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css" rel="stylesheet"/>

    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

    <style is:global>
      /* ==========================================================================
        1. Global Setup, Layouts & Reset Safeties
        ========================================================================== */
      *, *::before, *::after {
        box-sizing: border-box;
      }

      body {
        background-color: #0d1117;
        color: #c9d1d9;
        font-family: 'Montserrat', sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.7;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      .title-font {
        font-family: 'Orbitron', sans-serif;
      }

      .glass-card {
        background: rgba(22, 27, 34, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px); /* Safari support */
        border: 1px solid rgba(45, 102, 180, 0.2);
        border-radius: 12px;
      }

      .back-btn {
        color: #8b949e;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        padding: 0.5rem 0; /* Enhanced mobile touch target */
        transition: color 0.2s ease;
      }

      .back-btn:hover {
        color: #00ccff;
      }

      /* ==========================================================================
        2. Base Document / Rich-Text Typography
        ========================================================================== */
      .rich-text p {
        margin-top: 0;
        margin-bottom: 1.75rem;
        /* Balanced clamp: min 1rem, dynamic scaling, max 1.125rem */
        font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
        font-weight: 300;
        color: #e6edf3;
      }

      .rich-text h2 {
        font-family: 'Orbitron', sans-serif;
        color: #fff;
        /* Balanced clamp: min 1.4rem, dynamic scaling, max 2rem */
        font-size: clamp(1.4rem, 1.2rem + 1vw, 2rem);
        margin: 2.5rem 0 1rem 0;
        letter-spacing: 0.5px;
        line-height: 1.3;
      }

      .rich-text h3 {
        font-family: 'Orbitron', sans-serif;
        color: #fff;
        /* Balanced clamp: min 1.2rem, dynamic scaling, max 1.5rem */
        font-size: clamp(1.2rem, 1.1rem + 0.5vw, 1.5rem);
        margin: 2rem 0 0.75rem 0;
        line-height: 1.3;
      }

      .rich-text ul,
      .rich-text ol {
        margin-bottom: 1.75rem;
        padding-left: 1.25rem;
        color: #e6edf3;
      }

      .rich-text li {
        margin-bottom: 0.5rem;
        font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
        font-weight: 300;
      }

      .rich-text a {
        color: #00ccff;
        text-decoration: none;
        transition: opacity 0.2s ease;
      }

      .rich-text a:hover {
        opacity: 0.85;
      }

      .rich-text strong {
        color: #fff;
        font-weight: 600;
      }

      /* ==========================================================================
        3. Native Dash Quotes / Callouts (Tip & Warning Workspace)
        ========================================================================== */
      .rich-text blockquote {
        margin: 2rem 0;
        padding: 1.25rem 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 0 8px 8px 0;
        border-left: 3px solid #00ccff;
        color: #e6edf3;
      }

      .rich-text blockquote p {
        margin: 0 !important;
        font-size: 0.95rem;
        font-style: italic;
        line-height: 1.6;
      }

      .rich-text blockquote strong {
        color: #fff;
      }

      /* ==========================================================================
        4. Code Block Layout Safeties
        ========================================================================== */
      .rich-text pre {
        background: rgba(22, 27, 34, 0.8);
        border: 1px solid rgba(45, 102, 180, 0.2);
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.75rem;
        /* Smooth scrolling on mobile devices */
        -webkit-overflow-scrolling: touch; 
      }

      .rich-text pre code {
        background: transparent;
        color: #00ccff;
        padding: 0;
        border-radius: 0;
        font-size: 0.9em;
        white-space: pre;
      }

      .rich-text :not(pre) > code {
        background: rgba(45, 102, 180, 0.15);
        color: #00ccff;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
        word-break: break-word; /* Prevents long inline codes from breaking mobile layout */
      }

      /* ==========================================================================
        5. Custom Built Utility Foundations
        ========================================================================== */
      .btn-glow {
        background: linear-gradient(135deg, #1d3d6a, #21687a);
        color: #fff !important;
        text-shadow: 0 1px 2px rgba(0,0,0,0.2);
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        transition: box-shadow 0.2s ease, transform 0.1s ease;
      }

      .btn-glow:hover {
        box-shadow: 0 0 15px rgba(0, 204, 255, 0.5);
      }

      .btn-glow:active {
        transform: scale(0.98); /* Tactile feedback on mobile press */
      }

      /* ==========================================================================
        6. Keystatic Custom Components
        ========================================================================== */
      /* --- CTA Block --- */
      .keystatic-cta-block {
        margin: 2.5rem 0;
        padding: 1.5rem; /* Mobile first padding */
        border: 1px solid rgba(0, 204, 255, 0.2);
        text-align: left;
        position: relative;
      }

      .keystatic-cta-block h4 {
        color: #fff;
        font-family: 'Orbitron', sans-serif;
        font-size: 1.2rem;
        margin: 0 0 0.75rem 0;
        letter-spacing: 0.5px;
      }

      .keystatic-cta-block p {
        color: #8b949e !important;
        font-size: 0.95rem !important;
        margin: 0 0 1.5rem 0 !important;
        line-height: 1.6 !important;
      }

      .keystatic-cta-block a {
        display: inline-block;
        width: 100%; /* Full width on mobile for better ergonomics */
        text-align: center;
        padding: 0.85rem 1.5rem; /* Generous touch target sizing */
        border-radius: 4px;
        font-size: 0.85rem;
        text-decoration: none;
        font-family: 'Orbitron', sans-serif;
        font-weight: 600;
        color: #fff !important;
      }

      /* --- Alert Component Fallback Bounds --- */
      .keystatic-alert-block {
        margin: 2rem 0;
        padding: 1.25rem 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 0 8px 8px 0;
      }

      .rich-text .keystatic-alert-block p {
        color: #e6edf3 !important;
        font-size: 0.95rem !important;
        font-style: italic !important;
        margin: 0 !important;
        line-height: 1.6 !important;
        display: block !important;
      }

      .keystatic-alert-block.alert-tip {
        border-left: 3px solid #00ccff;
      }

      .keystatic-alert-block.alert-warning {
        border-left: 3px solid #ffcc00;
        background: rgba(255, 204, 0, 0.04);
      }

      /* ==========================================================================
        7. Desktop Media Query Enhancements (Break Upward)
        ========================================================================== */
      @media screen and (min-width: 768px) {
        .keystatic-cta-block {
          padding: 2.5rem; /* Roomier desktop layout */
        }

        .keystatic-cta-block a {
          width: auto; /* Revert full-width to naturally sizing button on desktop */
          padding: 0.65rem 1.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 0 1.5rem;">
      <a href="/articles" class="back-btn">
        <i class="ri-arrow-left-line"></i> Back to DNA Log
      </a>
    </div>

    <main style="max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 6rem 1.5rem;">
      
      <header style="margin-bottom: 2.5rem;">
        <span style="display: inline-block; background: rgba(0, 204, 255, 0.1); color: #00ccff; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; border: 1px solid rgba(0, 204, 255, 0.2); margin-bottom: 1rem;">
          {category}
        </span>
        
        <h1 class="title-font" style="font-size: clamp(1.75rem, 5vw, 2.6rem); color: #fff; line-height: 1.3; margin: 0 0 1.25rem 0; letter-spacing: 0.5px;">
          {title}
        </h1>
        
        <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; font-size: 0.85rem; color: #8b949e; border-bottom: 1px solid rgba(49, 56, 65, 0.6); padding-bottom: 1.5rem;">
          <span><i class="ri-user-3-line" style="color: #2d66b4;"></i> By {author}</span>
          <span><i class="ri-calendar-todo-line"></i> {date}</span>
          <span><i class="ri-time-line"></i> {readingTime}</span>
        </div>
      </header>

      {image && (
        <div style="width: 100%; height: clamp(200px, 45vw, 400px); overflow: hidden; border-radius: 12px; margin-bottom: 3rem; border: 1px solid rgba(49, 56, 65, 0.4);">
          <img src={image} alt={title} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      )}

      <article class="rich-text" style="margin-bottom: 5rem; color: #e6edf3; line-height: 1.8;">
        <div style="max-width: 750px; margin: 0 auto; line-height: 1.8;">
          <ArticleRenderer document={content} />
        </div>
      </article>

    </main>
  </body>
</html>